bbFilterType = input.string("Mean Reversion", title="🎪 BB Filter Type", options=["Mean Reversion", "Breakout", "Squeeze"], group="Technical Filters")

useADXFilter = input.bool(false, title="💪 Use ADX Filter", group="Technical Filters")
adxLength = input.int(14, title="💪 ADX Length", minval=1, group="Technical Filters")

useMACDFilter = input.bool(true, title="📈 Use MACD Filter", group="Technical Filters")
macdFastLength = input.int(12, title="📈 MACD Fast Length", minval=1, group="Technical Filters")
macdSlowLength = input.int(26, title="📈 MACD Slow Length", minval=1, group="Technical Filters")
macdSignalLength = input.int(9, title="📈 MACD Signal Length", minval=1, group="Technical Filters")
macdFilterType = input.string("Signal Cross", title="📈 MACD Filter Type", options=["Signal Cross", "Zero Line", "Histogram", "Trend"], group="Technical Filters")

useStochFilter = input.bool(true, title="🎯 Use Stochastic Filter", group="Technical Filters")
stochK = input.int(14, title="🎯 Stochastic %K Length", minval=1, group="Technical Filters")
stochD = input.int(3, title="🎯 Stochastic %D Smoothing", minval=1, group="Technical Filters")
stochOverbought = input.int(80, title="🎯 Stochastic Overbought", minval=70, maxval=95, group="Technical Filters")
stochOversold = input.int(20, title="🎯 Stochastic Oversold", minval=5, maxval=30, group="Technical Filters")

useBBFilter = input.bool(true, title="🎪 Use Bollinger Bands Filter", group="Technical Filters")
bbLength = input.int(20, title="🎪 BB Length", minval=1, group="Technical Filters")

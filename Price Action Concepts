// ==================== MULTI-TIMEFRAME SETTINGS ====================
useMTFConfirmation = input.bool(true, title="⏰ Enable Multi-Timeframe Confirmation", group="Multi-Timeframe")
htf1 = input.timeframe("15", title="⏰ Higher Timeframe 1", group="Multi-Timeframe")
htf2 = input.timeframe("60", title="⏰ Higher Timeframe 2", group="Multi-Timeframe") 
htf3 = input.timeframe("240", title="⏰ Higher Timeframe 3", group="Multi-Timeframe")
useHTF1 = input.bool(true, title="⏰ Use HTF1 Confirmation", group="Multi-Timeframe")
useHTF2 = input.bool(true, title="⏰ Use HTF2 Confirmation", group="Multi-Timeframe")
useHTF3 = input.bool(false, title="⏰ Use HTF3 Confirmation", group="Multi-Timeframe")
mtfMethod = input.string("Trend + Signals", title="⏰ MTF Confirmation Method", options=["Trend Only", "Signals Only", "Trend + Signals"], group="Multi-Timeframe")


var float totalPnL = 0.0
var float currentDrawdown = 0.0
var float maxDrawdownValue = 0.0
var float accountPeak = 100000.0

// Track trade performance
if longExit or shortExit
    totalTrades := totalTrades + 1
    if not na(entryPrice)
        tradePnL = inLongTrade ? (close - entryPrice) / entryPrice : (entryPrice - close) / entryPrice
        totalPnL := totalPnL + tradePnL
        if tradePnL > 0
            winningTrades := winningTrades + 1
        
        // Update drawdown
        currentBalance = 100000.0 + (totalPnL * 100000.0)
        if currentBalance > accountPeak
            accountPeak := currentBalance
        currentDrawdown := (accountPeak - currentBalance) / accountPeak * 100
        maxDrawdownValue := math.max(maxDrawdownValue, currentDrawdown)


useLiquiditySweeps = input.bool(true, title="💧 Enable Liquidity Sweep Detection", group="Liquidity Sweeps")
useDynamicBuffer = input.bool(true, title="💧 Use Dynamic Sweep Buffer", group="Liquidity Sweeps")

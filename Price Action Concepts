/@version=5
indicator(title="🚀 ULTIMATE UT BOT - PROFESSIONAL EDITION", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ==================== ULTIMATE UT BOT WITH ALL ADVANCED FEATURES ====================

// Basic colors
green = color.green
red = color.red
blue = color.blue
yellow = color.yellow
white = color.white
gray = color.gray
orange = color.orange
purple = color.purple
lime = color.lime
maroon = color.maroon
aqua = color.aqua
fuchsia = color.fuchsia

// ==================== CORE INPUTS ====================
utSensitivity = input.int(1, title="🎯 UT Bot Sensitivity", minval=1, maxval=10, group="Core Settings")
showDebug = input.bool(true, title="📊 Show Debug Info", group="Core Settings")

//@version=5
indicator("Custom Scalping + Swing Strategy (Hidden Lines)", overlay=true, max_labels_count=500, max_lines_count=500)

// Inputs for Indicators
// EMA Inputs
emaShortLength = input.int(9, minval=1, title="Short EMA Length")
emaMediumLength = input.int(21, minval=1, title="Medium EMA Length")
emaLongLength = input.int(200, minval=1, title="Long EMA Length")

// RSI Inputs
rsiLength = input.int(14, minval=1, title="RSI Length")
rsiOverbought = input.int(70, title="RSI Overbought Level")
rsiOversold = input.int(30, title="RSI Oversold Level")

// MACD Inputs
macdFastLength = input.int(12, minval=1, title="MACD Fast Length")
macdSlowLength = input.int(26, minval=1, title="MACD Slow Length")
macdSignalLength = input.int(9, minval=1, title="MACD Signal Length")

// ATR Inputs
atrLength = input.int(14, minval=1, title="ATR Length")
atrMultiplier = input.float(1.5, minval=0.1, title="ATR Multiplier")

// Bollinger Bands Inputs
bbLength = input.int(20, minval=1, title="Bollinger Bands Length")
bbMultiplier = input.float(2.0, minval=0.1, title="Bollinger Bands Multiplier")

// Ichimoku Inputs
conversionLineLength = input.int(9, minval=1, title="Ichimoku Conversion Line Length")
baseLineLength = input.int(26, minval=1, title="Ichimoku Base Line Length")
spanBLength = input.int(52, minval=1, title="Ichimoku Span B Length")

// Smart Money Concepts Inputs
showOrderBlocks = input.bool(true, title="Show Order Blocks")
showFairValueGaps = input.bool(true, title="Show Fair Value Gaps")

// Calculations
// EMA Calculations
emaShort = ta.ema(close, emaShortLength)
emaMedium = ta.ema(close, emaMediumLength)
emaLong = ta.ema(close, emaLongLength)

// RSI Calculation
rsi = ta.rsi(close, rsiLength)

// MACD Calculation
[macdLine, signalLine, _] = ta.macd(close, macdFastLength, macdSlowLength, macdSignalLength)

// ATR Calculation
atr = ta.atr(atrLength)

// Bollinger Bands Calculation
basis = ta.sma(close, bbLength)
deviation = ta.stdev(close, bbLength)
upperBand = basis + bbMultiplier * deviation
lowerBand = basis - bbMultiplier * deviation

// Ichimoku Cloud Calculation
conversionLine = ta.sma(ta.highest(high, conversionLineLength) + ta.lowest(low, conversionLineLength), 2)
baseLine = ta.sma(ta.highest(high, baseLineLength) + ta.lowest(low, baseLineLength), 2)
spanA = ta.sma(conversionLine + baseLine, 2)
spanB = ta.sma(ta.highest(high, spanBLength) + ta.lowest(low, spanBLength), 2)

// Entry and Exit Conditions
// Entry: EMA Crossover + RSI Confirmation + MACD Trend
longEntry = ta.crossover(emaShort, emaMedium) and rsi > 50 and macdLine > signalLine
shortEntry = ta.crossunder(emaShort, emaMedium) and rsi < 50 and macdLine < signalLine

// Exit: ATR-Based Stop Loss and Take Profit
longStopLoss = low - atr * atrMultiplier
longTakeProfit = close + atr * atrMultiplier

shortStopLoss = high + atr * atrMultiplier
shortTakeProfit = close - atr * atrMultiplier

// Plotting (Hidden Lines)
// EMA Plots
plot(emaShort, color=color.new(color.orange, 0), title="Short EMA", display=display.none)
plot(emaMedium, color=color.new(color.blue, 0), title="Medium EMA", display=display.none)
plot(emaLong, color=color.new(color.green, 0), title="Long EMA", display=display.none)

// RSI Overbought/Oversold Levels
hline(rsiOverbought, "Overbought", color=color.red, linestyle=hline.style_dashed, display=display.none)
hline(rsiOversold, "Oversold", color=color.green, linestyle=hline.style_dashed, display=display.none)

// Bollinger Bands Plots
plot(upperBand, color=color.new(color.blue, 50), title="Upper Bollinger Band", display=display.none)
plot(lowerBand, color=color.new(color.red, 50), title="Lower Bollinger Band", display=display.none)

// Ichimoku Cloud Plots
p1 = plot(spanA, color=color.new(color.green, 80), title="Span A", display=display.none)
p2 = plot(spanB, color=color.new(color.red, 80), title="Span B", display=display.none)
fill(p1, p2, color=color.new(color.gray, 90), title="Ichimoku Cloud", display=display.none)

// Entry and Exit Signals
plotshape(series=longEntry, title="Long Entry", location=location.belowbar, color=color.green, style=shape.labelup, text="BUY")
plotshape(series=shortEntry, title="Short Entry", location=location.abovebar, color=color.red, style=shape.labeldown, text="SELL")

// Stop Loss and Take Profit Levels
plot(longStopLoss, title="Long Stop Loss", color=color.red, linewidth=1, style=plot.style_line, display=display.none)
plot(longTakeProfit, title="Long Take Profit", color=color.green, linewidth=1, style=plot.style_line, display=display.none)
plot(shortStopLoss, title="Short Stop Loss", color=color.red, linewidth=1, style=plot.style_line, display=display.none)
plot(shortTakeProfit, title="Short Take Profit", color=color.green, linewidth=1, style=plot.style_line, display=display.none)

// Alerts
alertcondition(longEntry, title="Long Entry Alert", message="Long Entry Signal")
alertcondition(shortEntry, title="Short Entry Alert", message="Short Entry Signal")
